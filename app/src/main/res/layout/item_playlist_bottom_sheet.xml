<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp">

    <ImageView
        android:id="@+id/playlistCover"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:scaleType="centerCrop"
        android:background="@drawable/cover_placeholder_playlist"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:src="@drawable/img_placeholder" />

    <TextView
        android:id="@+id/playlistTitle"
        style="@style/TextNoTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintStart_toEndOf="@id/playlistCover"
        app:layout_constraintEnd_toStartOf="@id/playlistTrackCount"
        app:layout_constraintTop_toTopOf="@id/playlistCover"
        app:layout_constraintBottom_toBottomOf="@id/playlistCover"
        app:layout_constraintVertical_bias="0.3"
        tools:text="Название плейлиста" />

    <TextView
        android:id="@+id/playlistTrackCount"
        style="@style/BottomNavTextStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/playlistCover"
        app:layout_constraintBottom_toBottomOf="@id/playlistCover"
        tools:text="0 треков" />

</androidx.constraintlayout.widget.ConstraintLayout>
