<?xml version="1.0" encoding="utf-8"?>
<!-- Граф навигации: старт — Медиатека; плеер открывается из поиска или избранного с аргументом track -->
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/mediaFragment">

    <fragment
        android:id="@+id/mediaFragment"
        android:name="com.practicum.playlistmaker.presentation.media.MediaFragment"
        android:label="Медиатека"
        tools:layout="@layout/fragment_media">
        <action
            android:id="@+id/action_mediaFragment_to_playerFragment"
            app:destination="@id/playerFragment" />
    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.practicum.playlistmaker.presentation.search.SearchFragment"
        android:label="Поиск"
        tools:layout="@layout/fragment_search">
        <!-- Переход в плеер: передать Bundle с ключом "track" (Parcelable) -->
        <action
            android:id="@+id/action_searchFragment_to_playerFragment"
            app:destination="@id/playerFragment" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.practicum.playlistmaker.presentation.settings.SettingsFragment"
        android:label="Настройки"
        tools:layout="@layout/fragment_settings" />

    <fragment
        android:id="@+id/playerFragment"
        android:name="com.practicum.playlistmaker.presentation.player.PlayerFragment"
        android:label="Аудиоплеер"
        tools:layout="@layout/fragment_player">
        <!-- Обязательный аргумент: Track для отображения и previewUrl -->
        <argument
            android:name="track"
            app:argType="com.practicum.playlistmaker.domain.entity.Track"
            app:nullable="false" />
    </fragment>

</navigation>
